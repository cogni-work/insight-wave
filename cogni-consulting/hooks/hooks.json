{
  "version": "1.0",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/phase-gate-guard.sh",
            "timeout": 5,
            "enabled": true,
            "name": "phase-gate-guard",
            "description": "Warns if diamond phase prerequisites are incomplete before allowing phase skills to execute"
          }
        ]
      }
    ]
  }
}
