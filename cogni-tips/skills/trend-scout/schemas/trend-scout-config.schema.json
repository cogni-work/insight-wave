{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "trend-scout-config.schema.json",
  "title": "Tips Scout Configuration",
  "description": "Configuration file generated by trend-scout for deeper-research-1 consumption",
  "version": "2.0.0",
  "type": "object",
  "required": [
    "project_slug",
    "project_path",
    "generated_by",
    "research_type",
    "project_language",
    "industry",
    "tips_candidates",
    "deeper_analysis_integration"
  ],
  "properties": {
    "project_slug": {
      "type": "string",
      "description": "Semantic UUID for the project",
      "pattern": "^[a-z0-9-]+-[a-f0-9]{8}$"
    },
    "project_path": {
      "type": "string",
      "description": "Absolute path to project directory"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of generation"
    },
    "generated_by": {
      "type": "string",
      "const": "trend-scout"
    },
    "tips_scout_version": {
      "type": "string",
      "description": "Version of trend-scout skill"
    },
    "research_type": {
      "type": "string",
      "enum": ["smarter-service"],
      "description": "Research type for deeper-research-1"
    },
    "dok_level": {
      "type": "integer",
      "minimum": 1,
      "maximum": 4,
      "description": "Depth of Knowledge level"
    },
    "project_language": {
      "type": "string",
      "enum": ["de", "en"],
      "description": "Primary language for project"
    },
    "industry": {
      "type": "object",
      "required": ["primary", "primary_en", "primary_de", "subsector", "subsector_en", "subsector_de"],
      "properties": {
        "primary": {
          "type": "string",
          "description": "Industry slug"
        },
        "primary_en": {
          "type": "string",
          "description": "Industry name in English"
        },
        "primary_de": {
          "type": "string",
          "description": "Industry name in German"
        },
        "subsector": {
          "type": "string",
          "description": "Subsector slug"
        },
        "subsector_en": {
          "type": "string",
          "description": "Subsector name in English"
        },
        "subsector_de": {
          "type": "string",
          "description": "Subsector name in German"
        }
      }
    },
    "research_topic": {
      "type": "string",
      "description": "User's research topic/focus"
    },
    "organizing_concept": {
      "type": "string",
      "description": "Normalized organizing concept"
    },
    "tips_candidates": {
      "type": "object",
      "required": ["total", "source_distribution"],
      "properties": {
        "total": {
          "type": "integer",
          "const": 52
        },
        "source_distribution": {
          "type": "object",
          "properties": {
            "web_signal": {
              "type": "integer",
              "minimum": 0
            },
            "training": {
              "type": "integer",
              "minimum": 0
            },
            "user_proposed": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "web_research_status": {
          "type": "string",
          "enum": ["success", "partial", "failed", "disabled"]
        },
        "search_timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "scoring_metadata": {
          "type": "object",
          "description": "Aggregate scoring statistics for all candidates",
          "properties": {
            "avg_score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Average composite score across all candidates"
            },
            "confidence_distribution": {
              "type": "object",
              "properties": {
                "high": { "type": "integer", "minimum": 0 },
                "medium": { "type": "integer", "minimum": 0 },
                "low": { "type": "integer", "minimum": 0 },
                "uncertain": { "type": "integer", "minimum": 0 }
              }
            },
            "intensity_distribution": {
              "type": "object",
              "properties": {
                "level_1": { "type": "integer", "minimum": 0 },
                "level_2": { "type": "integer", "minimum": 0 },
                "level_3": { "type": "integer", "minimum": 0 },
                "level_4": { "type": "integer", "minimum": 0 },
                "level_5": { "type": "integer", "minimum": 0 }
              }
            },
            "scoring_framework_version": {
              "type": "string",
              "const": "1.0.0"
            }
          }
        },
        "items": {
          "type": "array",
          "items": { "$ref": "#/definitions/candidate" },
          "minItems": 52,
          "maxItems": 52
        }
      }
    },
    "dimensions": {
      "type": "object",
      "properties": {
        "externe-effekte": {
          "$ref": "#/definitions/dimensionCounts"
        },
        "neue-horizonte": {
          "$ref": "#/definitions/dimensionCounts"
        },
        "digitale-wertetreiber": {
          "$ref": "#/definitions/dimensionCounts"
        },
        "digitales-fundament": {
          "$ref": "#/definitions/dimensionCounts"
        }
      }
    },
    "deeper_analysis_integration": {
      "type": "object",
      "required": ["auto_load_candidates", "candidates_file"],
      "properties": {
        "auto_load_candidates": {
          "type": "boolean"
        },
        "candidates_file": {
          "type": "string",
          "description": "Relative path to agreed candidates JSON"
        },
        "skip_tips_selection": {
          "type": "boolean"
        },
        "skip_dimension_planning": {
          "type": "boolean"
        },
        "auto_configure_research_type": {
          "type": "boolean"
        },
        "auto_configure_dok_level": {
          "type": "boolean"
        },
        "auto_configure_language": {
          "type": "boolean"
        }
      }
    },
    "portfolio_linking": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "portfolio_file": {
          "type": ["string", "null"]
        }
      }
    }
  },
  "definitions": {
    "dimensionCounts": {
      "type": "object",
      "description": "Horizon-specific trend counts per dimension: 5 ACT + 5 PLAN + 3 OBSERVE = 13 per dimension, 52 total",
      "properties": {
        "act": {
          "type": "integer",
          "const": 5
        },
        "plan": {
          "type": "integer",
          "const": 5
        },
        "observe": {
          "type": "integer",
          "const": 3
        }
      }
    },
    "subcategory": {
      "type": "string",
      "enum": [
        "wirtschaft", "regulierung", "gesellschaft",
        "strategie", "fuehrung", "steuerung",
        "customer-experience", "produkte-services", "geschaeftsprozesse",
        "kultur", "mitarbeitende", "technologie"
      ],
      "description": "Subcategory within dimension for balanced trend discovery"
    },
    "dimensionSubcategoryMapping": {
      "description": "Valid subcategory-to-dimension mappings",
      "type": "object",
      "properties": {
        "externe-effekte": {
          "enum": ["wirtschaft", "regulierung", "gesellschaft"]
        },
        "neue-horizonte": {
          "enum": ["strategie", "fuehrung", "steuerung"]
        },
        "digitale-wertetreiber": {
          "enum": ["customer-experience", "produkte-services", "geschaeftsprozesse"]
        },
        "digitales-fundament": {
          "enum": ["kultur", "mitarbeitende", "technologie"]
        }
      }
    },
    "candidate": {
      "type": "object",
      "required": ["dimension", "subcategory", "horizon", "sequence", "name", "trend_statement", "keywords", "research_hint", "source", "score", "confidence_tier", "signal_intensity"],
      "properties": {
        "dimension": {
          "type": "string",
          "enum": ["externe-effekte", "neue-horizonte", "digitale-wertetreiber", "digitales-fundament"]
        },
        "subcategory": {
          "$ref": "#/definitions/subcategory"
        },
        "horizon": {
          "type": "string",
          "enum": ["act", "plan", "observe"]
        },
        "sequence": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 30,
          "description": "Short 1-2 word trend name"
        },
        "trend_statement": {
          "type": "string",
          "minLength": 50,
          "maxLength": 250,
          "description": "Concise 30-50 word statement of what is happening with this trend"
        },
        "keywords": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 2,
          "maxItems": 5
        },
        "research_hint": {
          "type": "string",
          "minLength": 30,
          "maxLength": 150,
          "description": "Investigation guidance (20-30 words) for TIPS-aware research question generation"
        },
        "source": {
          "type": "string",
          "enum": ["web-signal", "training", "user_proposed"]
        },
        "source_url": {
          "type": ["string", "null"],
          "format": "uri"
        },
        "freshness_date": {
          "type": ["string", "null"],
          "pattern": "^\\d{4}-(0[1-9]|1[0-2])$",
          "description": "YYYY-MM format"
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Composite trend score (0.0-1.0) based on multi-criteria weighting"
        },
        "confidence_tier": {
          "type": "string",
          "enum": ["high", "medium", "low", "uncertain"],
          "description": "Signal confidence based on source triangulation"
        },
        "signal_intensity": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5,
          "description": "Ansoff weak signal level (1=turbulence, 5=foreseeable)"
        },
        "component_scores": {
          "type": "object",
          "description": "Individual scoring components for transparency",
          "properties": {
            "impact": { "type": "number", "minimum": 0, "maximum": 1 },
            "probability": { "type": "number", "minimum": 0, "maximum": 1 },
            "strategic_fit": { "type": "number", "minimum": 0, "maximum": 1 },
            "source_quality": { "type": "number", "minimum": 0, "maximum": 1 },
            "signal_strength": { "type": "number", "minimum": 0, "maximum": 1 },
            "uncertainty_penalty": { "type": "number", "minimum": 0, "maximum": 0.1 }
          }
        }
      }
    }
  }
}
