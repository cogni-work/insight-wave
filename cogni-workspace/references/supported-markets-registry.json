        "Nordics",
        "UK",
        "US/NA",
        "APAC",
        "LATAM",
        "MEA",
        "CN",
        "JP"
      ],
      "tail_clause": "market-segmented propositions, competitors, and customer personas — not one-size-fits-all"
    }
