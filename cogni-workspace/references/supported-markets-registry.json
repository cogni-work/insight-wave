{
  "$schema": "supported-markets-registry-v1",
  "_doc": "Consolidated source of truth for which markets each market-aware insight-wave plugin supports, and how. Read by cogni-docs doc-generate (Step 2d Markets Callout injection), doc-power (market-aware IS/DOES/MEANS), doc-hub (Working-across-markets subsection in plugin guides), doc-readme-root (ecosystem-level localized-for-Europe paragraph), and doc-audit (Check 15 Markets Callout Consistency). This is the canonical upstream registry. cogni-docs ships a local fallback projection at references/market-coverage.json — when this upstream file exists, generators prefer it; the fallback is the graceful-degradation path used when a repo has not yet landed the upstream consolidation.",
  "provenance": "canonical upstream",
  "upstream_path": "cogni-workspace/references/supported-markets-registry.json",
  "consolidates": [
    "cogni-research/references/market-sources.json",
    "cogni-trends/skills/trend-research/references/region-authority-sources.json"
  ],
  "schema_version": "1.1.0",
  "last_updated": "2026-04-30",
  "plugins": {
    "cogni-research": {
      "emphasis": "per-market authority sources and bilingual local-language search",
      "mechanism": "authority-source",
      "market_count_claim": 21,
      "callout_lede": "21 localized European, Anglo, LATAM, and APAC markets",
      "primary_authorities_shown_in_callout": [
        "DACH",
        "FR",
        "IT",
        "PL",
        "NL",
        "ES",
        "MX",
        "BR",
        "CN"
      ],
      "tail_clause": "bilingual queries, per-market authority sources, output in your chosen language"
    },
    "cogni-trends": {
      "emphasis": "per-market trend authority searches with local-language subsector qualifiers",
      "mechanism": "bilingual-query",
      "market_count_claim": 8,
      "callout_lede": "8 European and Anglo markets with per-region trend authorities",
      "primary_authorities_shown_in_callout": [
        "DACH",
        "FR",
        "IT",
        "PL",
        "NL",
        "ES"
      ],
      "tail_clause": "DE/EN bilingual research against regional authorities — no generic US-centric datasets"
    },
    "cogni-portfolio": {
      "emphasis": "market segmentation and TAM/SAM/SOM sizing across 25 regions",
      "mechanism": "region-segmentation",
